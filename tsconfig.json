{
  "compilerOptions": {
      "moduleDetection": "force",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "target": "esnext",
      "allowJs": true,
      "esModuleInterop": true,
      "isolatedModules": true,
      },
  "include": [
      "src/**/*",
      "eslint.config.ts"
  ],
  "exclude": [
      "node_modules",
      "dist"
  ]
}